{
  "name": "wechat-official-account-collect-tool-desktop",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop": "vite build",
    "package:desktop": "npm run build && electron-builder --publish never",
    "package:desktop:dir": "npm run build && electron-builder --dir --publish never",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.94.5",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.wechat.scraper.desktop",
    "productName": "WeChatScraper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**",
      "package.json"
    ],
    "asar": true
  }
}
